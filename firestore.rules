rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    match /verbs/{verbId} {
      allow read: if true;
      allow write: if false;
    }

    match /users/{userId}/progress/{progressId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }
  }
}
